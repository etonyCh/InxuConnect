generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  name           String
  password       String
  phone          String?
  phoneVerified  Boolean     @default(false)
  kycStatus      KycStatus   @default(NONE)
  otpCode        String?
  otpExpiresAt   DateTime?
  role           Role        @default(GUEST)
  badge          Badge       @default(NONE)
  kycRequest     KycRequest?
  createdAt      DateTime    @default(now())
  listings       Listing[]
  bookings          Booking[]
  messages          Message[]
  authoredReviews   Review[]          @relation("AuthoredReviews")
  targetedReviews   Review[]          @relation("TargetedReviews")
  referredByAgentId String?
  referredByAgent   User?             @relation("AgentReferrals", fields: [referredByAgentId], references: [id])
  referredUsers     User[]            @relation("AgentReferrals")
  b2bCompanyId      String?
  b2bCompany        B2bCompany?       @relation(fields: [b2bCompanyId], references: [id])
  microSavingsEnabled Boolean     @default(false)
  savingsBalance      Int         @default(0)
}

model Listing {
  id                 String                @id @default(cuid())
  title              String
  description        String
  price              Int
  city               String
  address            String?
  latitude           Float?
  longitude          Float?
  bedrooms           Int                   @default(1)
  bathrooms          Int                   @default(1)
  taxiMotoDistance   Int?
  surchargeGenerator Int                   @default(0)
  ownerId            String
  owner              User                  @relation(fields: [ownerId], references: [id])
  bookings           Booking[]
  photos             Photo[]
  amenities          Amenity[]
  availabilities     ListingAvailability[]
  services           ServiceItem[]
  stagingRequests    VirtualStagingRequest[]
  country            String                @default("Burundi")
  currency           String                @default("BIF")
  createdAt          DateTime              @default(now())
}

model Photo {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())
}

model Amenity {
  id       String    @id @default(cuid())
  name     String    @unique // ex: "generator", "water_tank", "starlink"
  listings Listing[]
}

model ListingAvailability {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date        DateTime
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([listingId, date])
}

model Booking {
  id         String        @id @default(cuid())
  listingId  String
  listing    Listing       @relation(fields: [listingId], references: [id])
  guestId    String
  guest      User          @relation(fields: [guestId], references: [id])
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Int
  status     BookingStatus @default(PENDING)
  payment    Payment?
  messages   Message[]
  reviews      Review[]
  services     ServiceBooking[]
  b2bCompanyId String?
  b2bCompany   B2bCompany?      @relation(fields: [b2bCompanyId], references: [id])
  createdAt    DateTime         @default(now())
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String        @unique
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider  PaymentMethod
  reference String        @unique
  amount    Int
  status    PaymentStatus @default(PENDING)
  payoutAt  DateTime?
  createdAt DateTime      @default(now())
}

enum PaymentMethod {
  ECOCASH
  LUMICASH
}

enum PaymentStatus {
  PENDING
  ESCROWED
  PAID_OUT
  FAILED
  REFUNDED
}

model KycRequest {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cniUrl    String
  selfieUrl String
  status    KycStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  GUEST
  HOST
  AGENT
  ADMIN
}

enum Badge {
  NONE
  VERIFIED
  FIABLE
  SUPERHOST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

model Message {
  id             String   @id @default(cuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  bodyOriginal   String
  bodyTranslated String
  lang           String   // "FR" or "RN"
  createdAt      DateTime @default(now())
}

model Review {
  id          String    @id @default(cuid())
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation("AuthoredReviews", fields: [authorId], references: [id], onDelete: Cascade)
  targetId    String
  target      User      @relation("TargetedReviews", fields: [targetId], references: [id], onDelete: Cascade)
  rating      Int       // 1 to 5
  comment     String
  revealedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([bookingId, authorId])
}

model AgentCommission {
  id         String   @id @default(cuid())
  agentId    String
  bookingId  String
  amount     Int      // Montant en BIF
  createdAt  DateTime @default(now())
}

model ServiceItem {
  id          String           @id @default(cuid())
  listingId   String
  listing     Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       Int              // Prix en BIF
  createdAt   DateTime         @default(now())
  bookings    ServiceBooking[]
}

model ServiceBooking {
  id            String      @id @default(cuid())
  bookingId     String
  booking       Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceItemId String
  serviceItem   ServiceItem @relation(fields: [serviceItemId], references: [id], onDelete: Cascade)
  status        String      @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt     DateTime    @default(now())
}

model B2bCompany {
  id               String    @id @default(cuid())
  name             String
  tier             String    // "PME" ou "ONG_INTERNATIONALE"
  saasFee          Int       // 50000 ou 200000 BIF
  maxPricePerNight Int       @default(100000) // Limite de prix politique de voyage
  createdAt        DateTime  @default(now())
  users            User[]
  bookings         Booking[]
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  apiKey    String   @unique
  createdAt DateTime @default(now())
}

model VirtualStagingRequest {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  sceneUrl  String?  // URL du mock 3D
  price     Int      @default(5000) // 5000 BIF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}